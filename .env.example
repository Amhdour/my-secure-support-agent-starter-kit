# Environment profile
ENVIRONMENT=development
LOG_LEVEL=INFO

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
REQUEST_TIMEOUT_SECONDS=30

# Retrieval (template values only)
RETRIEVAL_BACKEND=stub
RETRIEVAL_TOP_K=5
RETRIEVAL_INDEX_PATH=./artifacts/index

# Tooling (template values only)
TOOLS_ALLOWLIST=
TOOL_EXECUTION_ENABLED=false

# Policy engine (template values only)
POLICY_MODE=enforce
POLICY_BUNDLE_PATH=./policies/bundles/default

# Telemetry / audit (template values only)
TELEMETRY_ENABLED=true
AUDIT_SINK=stdout
AUDIT_LOG_PATH=./artifacts/logs/audit.log

# Launch gate
LAUNCH_GATE_STRICT=true
