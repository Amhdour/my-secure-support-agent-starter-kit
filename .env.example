# =============================================================================
# Secure Support Agent Starter Kit — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# On Replit, these are also set via the Secrets/Environment tab.
#
# CLASSIFICATION:
#   [CONFIG]  Safe default, no sensitive data
#   [SECRET]  Must be added via Replit Secrets when integrating real providers
# =============================================================================

# --- Environment Profile [CONFIG] ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Application [CONFIG] ---
APP_HOST=0.0.0.0
APP_PORT=8000
REQUEST_TIMEOUT_SECONDS=30

# --- Retrieval [CONFIG] ---
RETRIEVAL_BACKEND=stub
RETRIEVAL_TOP_K=5
RETRIEVAL_INDEX_PATH=./artifacts/index

# --- Tooling [CONFIG] ---
TOOLS_ALLOWLIST=
TOOL_EXECUTION_ENABLED=false

# --- Policy Engine [CONFIG] ---
POLICY_MODE=enforce
POLICY_BUNDLE_PATH=./policies/bundles/default

# --- Telemetry / Audit [CONFIG] ---
TELEMETRY_ENABLED=true
AUDIT_SINK=stdout
AUDIT_LOG_PATH=./artifacts/logs/audit.log

# --- Launch Gate [CONFIG] ---
LAUNCH_GATE_STRICT=true

# =============================================================================
# FUTURE SECRETS (not required for scaffold operation)
# Add these via Replit Secrets when integrating real providers:
#
#   LLM_API_KEY          [SECRET]  API key for LLM provider (OpenAI, Anthropic, etc.)
#   VECTOR_STORE_URL     [SECRET]  Connection string for vector store
#   VECTOR_STORE_API_KEY [SECRET]  API key for vector store
#   TICKETING_API_KEY    [SECRET]  API key for ticketing system integration
#   WEBHOOK_SECRET       [SECRET]  Shared secret for inbound webhook verification
# =============================================================================
